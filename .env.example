# BOCRA Website - Environment Variables
# Copy this file to .env.local for local development

VITE_SUPABASE_URL=https://cyalwtuladeexxfsbrcs.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Google Translate API ──────────────────────────────────
# This key is NOT used in the frontend. It is stored as a
# Supabase Edge Function secret and never exposed to browsers.
#
# Setup steps:
#   1. Enable the Cloud Translation API in Google Cloud Console
#   2. Create an API key (restrict to Cloud Translation API only)
#   3. Store it as a Supabase secret:
#      supabase secrets set GOOGLE_TRANSLATE_API_KEY=your_key_here
#   4. Deploy the Edge Function:
#      supabase functions deploy translate
#
# GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here
